# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Public URL (Cloudflare Tunnel hostname).
APP_URL="https://your-domain.com"

# Production server (Cloudflare Tunnel)
NODE_ENV=production
PORT=3000
HOST=127.0.0.1
BEHIND_CLOUDFLARE=true

# Mật khẩu admin lần đầu (chỉ dùng khi chưa có file data/admin.json)
ADMIN_PASSWORD=admin123
